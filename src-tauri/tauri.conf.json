{
  "$schema": "https://raw.githubusercontent.com/nicegram/nicegram-ios-tauri-v2/refs/heads/tauri-v2/core/tauri-config-schema/schema.json",
  "productName": "WebDAV-Client",
  "version": "0.1.0",
  "identifier": "com.webdav-client.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
    "icons/32x32.png",
    "icons/128x128.png",
    "icons/128x128@2x.png",
    "icons/icon.icns",
    "icons/icon.ico"
  ]
  },
  "app": {
    "windows": [
      {
        "title": "WebDAV-Client",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "shadow": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "scope": ["$TEMP/webdav-preview/**"]
      }
    }
  },
  "plugins": {}
}
