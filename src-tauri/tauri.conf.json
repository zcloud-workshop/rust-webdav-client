{
  "$schema": "https://raw.githubusercontent.com/nicegram/nicegram-ios-tauri-v2/refs/heads/tauri-v2/core/tauri-config-schema/schema.json",
  "productName": "WebDAV-Client",
  "version": "0.1.2",
  "identifier": "com.webdav-client.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "WebDAV-Client",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {}
}
